{{ define "email.subject" -}}
{{ if eq .Status "firing" -}}
  🔴 [{{ .CommonLabels.severity | toUpper }}] {{ .CommonAnnotations.summary }}
{{- else -}}
  ✅ [RESOLVED] {{ .CommonAnnotations.summary }}
{{- end }}
{{- end }}

{{ define "email.html" -}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Alert Notification</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background-color: #f0f2f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 14px;
      color: #1a1a2e;
      padding: 32px 16px;
    }
    .wrapper {
      max-width: 600px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      border-radius: 12px 12px 0 0;
      padding: 28px 32px;
      text-align: center;
    }
    .header.firing   { background: linear-gradient(135deg, #1a0510 0%, #3d0b1a 100%); }
    .header.resolved { background: linear-gradient(135deg, #051a0f 0%, #0b3d1e 100%); }

    .header-icon { font-size: 40px; margin-bottom: 12px; }

    .header-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.3px;
      margin-bottom: 6px;
    }
    .firing   .header-title { color: #ff6b8a; }
    .resolved .header-title { color: #4ade80; }

    .header-subtitle {
      font-size: 13px;
      opacity: 0.6;
    }
    .firing   .header-subtitle { color: #fecdd3; }
    .resolved .header-subtitle { color: #bbf7d0; }

    /* Body */
    .body {
      background: #ffffff;
      padding: 32px;
    }

    /* Status badge */
    .status-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
    }
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
    }
    .badge-critical { background: #fee2e2; color: #dc2626; }
    .badge-warning  { background: #fef3c7; color: #d97706; }
    .badge-resolved { background: #dcfce7; color: #16a34a; }
    .badge-info     { background: #dbeafe; color: #2563eb; }

    .timestamp {
      font-size: 12px;
      color: #9ca3af;
      margin-left: auto;
    }

    /* Alert cards */
    .section-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #9ca3af;
      margin-bottom: 12px;
    }

    .alert-card {
      border-radius: 8px;
      border: 1px solid #e5e7eb;
      overflow: hidden;
      margin-bottom: 12px;
    }

    .alert-card-header {
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .firing-card   .alert-card-header { background: #fff5f5; border-bottom: 1px solid #fecaca; }
    .resolved-card .alert-card-header { background: #f0fdf4; border-bottom: 1px solid #bbf7d0; }

    .alert-name {
      font-weight: 600;
      font-size: 14px;
    }
    .firing-card   .alert-name { color: #dc2626; }
    .resolved-card .alert-name { color: #16a34a; }

    .alert-card-body { padding: 14px 16px; }

    .meta-row {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 8px;
    }
    .meta-label {
      font-size: 11px;
      font-weight: 600;
      color: #9ca3af;
      width: 80px;
      flex-shrink: 0;
      padding-top: 1px;
      text-transform: uppercase;
    }
    .meta-value {
      font-size: 13px;
      color: #374151;
      line-height: 1.5;
    }
    .meta-value code {
      background: #f3f4f6;
      padding: 1px 6px;
      border-radius: 4px;
      font-family: 'Courier New', monospace;
      font-size: 12px;
      color: #4b5563;
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #f3f4f6;
      margin: 24px 0;
    }

    /* Action button */
    .action-section { text-align: center; margin: 28px 0 8px; }
    .btn {
      display: inline-block;
      padding: 12px 28px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      letter-spacing: 0.2px;
    }
    .btn-primary {
      background: linear-gradient(135deg, #1e40af, #2563eb);
      color: #ffffff;
    }

    /* Footer */
    .footer {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-top: none;
      border-radius: 0 0 12px 12px;
      padding: 20px 32px;
      text-align: center;
    }
    .footer p {
      font-size: 12px;
      color: #9ca3af;
      line-height: 1.6;
    }
    .footer a { color: #6b7280; text-decoration: none; }

    /* Summary box */
    .summary-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-left: 4px solid #3b82f6;
      border-radius: 6px;
      padding: 14px 16px;
      margin-bottom: 20px;
    }
    .summary-box.firing   { border-left-color: #ef4444; background: #fff8f8; }
    .summary-box.resolved { border-left-color: #22c55e; background: #f8fff9; }
    .summary-box p { font-size: 13px; color: #4b5563; line-height: 1.6; }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- Header -->
  <div class="header {{ .Status }}">
    <div class="header-icon">
      {{ if eq .Status "firing" }}🚨{{ else }}✅{{ end }}
    </div>
    <div class="header-title">
      {{ if eq .Status "firing" }}Incident Detected{{ else }}Incident Resolved{{ end }}
    </div>
    <div class="header-subtitle">
      TechCorp Monitoring System · {{ len .Alerts }} alert(s)
    </div>
  </div>

  <!-- Body -->
  <div class="body">

    <!-- Status row -->
    <div class="status-row">
      {{ if eq .Status "firing" }}
        {{ if eq .CommonLabels.severity "critical" }}
          <span class="badge badge-critical">🔴 Critical</span>
        {{ else }}
          <span class="badge badge-warning">⚠️ Warning</span>
        {{ end }}
      {{ else }}
        <span class="badge badge-resolved">✅ Resolved</span>
      {{ end }}
      <span class="timestamp">{{ .Alerts.Firing | len }} firing · {{ .Alerts.Resolved | len }} resolved</span>
    </div>

    <!-- Summary -->
    {{ if .CommonAnnotations.summary }}
    <div class="summary-box {{ .Status }}">
      <p><strong>{{ .CommonAnnotations.summary }}</strong></p>
      {{ if .CommonAnnotations.description }}
      <p style="margin-top: 6px; opacity: 0.8;">{{ .CommonAnnotations.description }}</p>
      {{ end }}
    </div>
    {{ end }}

    <!-- Firing Alerts -->
    {{ if .Alerts.Firing }}
    <div class="section-title">🔥 Firing Alerts ({{ len .Alerts.Firing }})</div>
    {{ range .Alerts.Firing }}
    <div class="alert-card firing-card">
      <div class="alert-card-header">
        <span class="alert-name">{{ .Labels.alertname }}</span>
        {{ if .Labels.severity }}
          {{ if eq .Labels.severity "critical" }}
            <span class="badge badge-critical">Critical</span>
          {{ else }}
            <span class="badge badge-warning">Warning</span>
          {{ end }}
        {{ end }}
      </div>
      <div class="alert-card-body">
        {{ if .Labels.job }}
        <div class="meta-row">
          <span class="meta-label">Service</span>
          <span class="meta-value"><code>{{ .Labels.job }}</code></span>
        </div>
        {{ end }}
        {{ if .Annotations.summary }}
        <div class="meta-row">
          <span class="meta-label">Summary</span>
          <span class="meta-value">{{ .Annotations.summary }}</span>
        </div>
        {{ end }}
        {{ if .Annotations.description }}
        <div class="meta-row">
          <span class="meta-label">Detail</span>
          <span class="meta-value">{{ .Annotations.description }}</span>
        </div>
        {{ end }}
        <div class="meta-row">
          <span class="meta-label">Mulai</span>
          <span class="meta-value">{{ .StartsAt.Format "02 Jan 2006 · 15:04:05 UTC" }}</span>
        </div>
      </div>
    </div>
    {{ end }}
    {{ end }}

    <!-- Resolved Alerts -->
    {{ if .Alerts.Resolved }}
    <hr class="divider" />
    <div class="section-title">✅ Resolved Alerts ({{ len .Alerts.Resolved }})</div>
    {{ range .Alerts.Resolved }}
    <div class="alert-card resolved-card">
      <div class="alert-card-header">
        <span class="alert-name">{{ .Labels.alertname }}</span>
        <span class="badge badge-resolved">Resolved</span>
      </div>
      <div class="alert-card-body">
        {{ if .Labels.job }}
        <div class="meta-row">
          <span class="meta-label">Service</span>
          <span class="meta-value"><code>{{ .Labels.job }}</code></span>
        </div>
        {{ end }}
        {{ if .Annotations.summary }}
        <div class="meta-row">
          <span class="meta-label">Summary</span>
          <span class="meta-value">{{ .Annotations.summary }}</span>
        </div>
        {{ end }}
        <div class="meta-row">
          <span class="meta-label">Mulai</span>
          <span class="meta-value">{{ .StartsAt.Format "02 Jan 2006 · 15:04:05 UTC" }}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">Selesai</span>
          <span class="meta-value">{{ .EndsAt.Format "02 Jan 2006 · 15:04:05 UTC" }}</span>
        </div>
      </div>
    </div>
    {{ end }}
    {{ end }}

    <!-- CTA Button -->
    <div class="action-section">
      <a href="http://localhost:3000" class="btn btn-primary">
        Buka Grafana Dashboard →
      </a>
    </div>

  </div>

  <!-- Footer -->
  <div class="footer">
    <p>
      Email ini dikirim otomatis oleh <strong>TechCorp Monitoring System</strong><br/>
      Prometheus + Grafana + Alertmanager<br/>
      <a href="http://localhost:9093">Alertmanager</a> ·
      <a href="http://localhost:9090">Prometheus</a> ·
      <a href="http://localhost:3001">Uptime Kuma</a>
    </p>
  </div>

</div>
</body>
</html>
{{- end }}
