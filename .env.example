# ─── Alertmanager SMTP ───────────────────────────────────
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_FROM=your_email@gmail.com
ALERTMANAGER_SMTP_USERNAME=your_email@gmail.com
ALERTMANAGER_SMTP_PASSWORD=your_gmail_app_password
ALERTMANAGER_EMAIL_TO=recipient_email@gmail.com

# ─── Grafana Admin ───────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_this_password

# ─── Grafana SMTP ────────────────────────────────────────
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your_email@gmail.com
GF_SMTP_PASSWORD=your_gmail_app_password
GF_SMTP_FROM_ADDRESS=your_email@gmail.com
